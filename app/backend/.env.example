# Core
GISDATAMONITOR_APP_NAME=GISDataMonitor 后端服务
GISDATAMONITOR_ENV=dev
GISDATAMONITOR_API_PREFIX=/api/v1
GISDATAMONITOR_TIMEZONE=Asia/Shanghai
GISDATAMONITOR_FRONTEND_ORIGIN=*

# Database
GISDATAMONITOR_DATABASE_URL=sqlite:///./gisdatamonitor.sqlite3

# Network / proxy
GISDATAMONITOR_HTTP_PROXY=
GISDATAMONITOR_HTTPS_PROXY=
GISDATAMONITOR_CONNECTOR_TIMEOUT_SEC=30

# Realtime sync
GISDATAMONITOR_SCHEDULER_ENABLED=true
GISDATAMONITOR_SYNC_INTERVAL_MINUTES=10
GISDATAMONITOR_SYNC_RUN_ON_STARTUP=false
GISDATAMONITOR_SYNC_MAX_RETRY=2
GISDATAMONITOR_EVENT_LINK_RADIUS_KM=80
GISDATAMONITOR_SYNC_FAILURE_OPEN_CIRCUIT_THRESHOLD=3
GISDATAMONITOR_SYNC_CIRCUIT_OPEN_MINUTES=10

# Area (Jiangxi bbox)
GISDATAMONITOR_JIANGXI_BBOX=113.67845,24.58754,118.59998,30.14784

# Connectors
GISDATAMONITOR_USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_week.geojson
GISDATAMONITOR_GDELT_ENABLED=true
GISDATAMONITOR_GDELT_QUERY=(earthquake OR wildfire OR flood OR energy OR power OR refinery) AND (china OR jiangxi)
GISDATAMONITOR_GDELT_MAX_RECORDS=200
GISDATAMONITOR_GDELT_FALLBACK_MAX_RECORDS=120
GISDATAMONITOR_GDELT_TIMEOUT_SEC=15
GISDATAMONITOR_GDELT_TIMESPAN=7days
GISDATAMONITOR_GDELT_RATE_LIMIT_COOLDOWN_MINUTES=20

# Key-based connector (optional). Without key, FIRMS connector is skipped.
GISDATAMONITOR_FIRMS_API_KEY=
GISDATAMONITOR_FIRMS_FEED_TEMPLATE=https://firms.modaps.eosdis.nasa.gov/api/area/csv/{api_key}/VIIRS_NOAA20_NRT/{bbox}/1

# Optional expansion connectors
GISDATAMONITOR_AIS_FEED_URL=
GISDATAMONITOR_PORT_FEED_URL=

# AI enrichment (OpenAI-compatible endpoint, optional)
GISDATAMONITOR_ANALYSIS_ENABLED=true
GISDATAMONITOR_ANALYSIS_MAX_EVENTS_PER_CYCLE=2000
GISDATAMONITOR_ANALYSIS_RECHECK_HOURS=6
GISDATAMONITOR_ANALYSIS_USE_LLM=false
GISDATAMONITOR_ANALYSIS_LLM_BASE_URL=
GISDATAMONITOR_ANALYSIS_LLM_API_KEY=
GISDATAMONITOR_ANALYSIS_LLM_MODEL=gpt-4o-mini
GISDATAMONITOR_ANALYSIS_LLM_TIMEOUT_SEC=25

# SQLite maintenance (optional, enabled by default)
GISDATAMONITOR_MAINTENANCE_ENABLED=true
GISDATAMONITOR_SYNC_LOG_RETENTION_DAYS=14
GISDATAMONITOR_CONNECTOR_HEALTH_RETENTION_DAYS=14
GISDATAMONITOR_ANALYSIS_LOG_RETENTION_DAYS=30
GISDATAMONITOR_PLAYBACK_CACHE_RETENTION_DAYS=14
GISDATAMONITOR_EVENT_RAW_RETENTION_DAYS=14
