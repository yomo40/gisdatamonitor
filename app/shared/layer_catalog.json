    {
      "id": "events",
      "kind": "realtime",
      "format": ["geojson", "mvt"],
      "endpoint_geojson": "/api/v1/map/layers/events.geojson",
      "endpoint_mvt": "/api/v1/map/tiles/events/{z}/{x}/{y}.mvt"
